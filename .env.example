# ── Required ───────────────────────────────────────────────────────────────────
# OMDb (movies/TV) — free key at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here

# ── Optional: LLM answer generation ───────────────────────────────────────────
# Groq (free, no credit card) — https://console.groq.com
# GROQ_API_KEY=your_groq_api_key_here

# ── Optional: Hugging Face deployment ─────────────────────────────────────────
# Used by GitHub Actions to push to HF Spaces (also set as a GitHub secret)
# HF_TOKEN=your_hf_token_here

# Override the HF model repo for auto-download (default: Aliadenawil/atlas-models)
# MODEL_REPO=Aliadenawil/atlas-models

# ── Optional: deployment mode ──────────────────────────────────────────────────
# Set to `hf` to use browser audio input instead of local microphone capture.
# DEPLOY_MODE=hf

# ── Optional: Google Drive sync ───────────────────────────────────────────────
# Service account credentials JSON file path (or paste JSON as single line)
# GOOGLE_SERVICE_ACCOUNT_JSON=credentials.json
#
# Drive folder IDs (pre-created for this project)
# DRIVE_ROOT_FOLDER_ID=your_root_folder_id
# DRIVE_RAW_RECORDINGS_FOLDER_ID=your_raw_recordings_folder_id
# DRIVE_WAKEWORD_DATASET_FOLDER_ID=your_wakeword_dataset_folder_id
# DRIVE_VOICEPRINTS_FOLDER_ID=your_voiceprints_folder_id

# ── Optional: UI bypass PIN ────────────────────────────────────────────────────
# PIN to bypass voice verification and wakeword detection in the UI (useful for demos/testing)
VA_BYPASS_PIN=1234
