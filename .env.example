# ── Required API Keys ─────────────────────────────────────────────────────────
# OMDb (movies/TV) — free key at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Set to `hf` to use browser audio input instead of local microphone capture.
DEPLOY_MODE=hf

# PIN to bypass voice verification in the UI (useful for demos/testing)
VA_BYPASS_PIN=1234
